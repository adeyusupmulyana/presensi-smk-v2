# Environment Variables untuk Presensi SMK
# Copy file ini menjadi .env.local dan isi dengan nilai dari Supabase

# Supabase Configuration
# Dapatkan nilai ini dari: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
